// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("MYSQL_URL")
}

model User {
  id          Int        @id @default(autoincrement())
  email       String     @unique
  name        String?
  phone       String?
  role        Role       @default(CUSTOMER)
  createdAt   DateTime   @default(now())
  orders      Order[]
  payments    Payment[]
}

enum Role {
  CUSTOMER
  ADMIN
}

//
// Products & Services
//
model Product {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  type        ProductType
  price       Float
  currency    String      @default("usd")
  // optional fields
  location    String?     // for tours
  duration    Int?        // for tours, in days
  startDate   DateTime?   // for tours
  endDate     DateTime?   // for tours
  createdAt   DateTime    @default(now())
  orders      Order[]
}

enum ProductType {
  MINI_SPEAKER
  NDGO_PROGRAM
  TOUR
}

//
// Orders & Payments
//
model Order {
  id          Int        @id @default(autoincrement())
  user        User       @relation(fields: [userId], references: [id])
  userId      Int
  product     Product    @relation(fields: [productId], references: [id])
  productId   Int
  status      OrderStatus @default(PENDING)
  quantity    Int        @default(1)
  scheduledAt DateTime?   // for tours or program
  createdAt   DateTime    @default(now())
  payment     Payment?
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Payment {
  id          Int        @id @default(autoincrement())
  order       Order      @relation(fields: [orderId], references: [id])
  orderId     Int
  user        User       @relation(fields: [userId], references: [id])
  userId      Int
  amount      Float
  currency    String
  reference   String     @unique // stripe payment_intent id or checkout session id
  provider    PaymentProvider
  status      PaymentStatus
  createdAt   DateTime   @default(now())
}

enum PaymentProvider {
  STRIPE
  MOMO
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}
