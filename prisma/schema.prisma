// --------------------
// GENERATOR & DATASOURCE
// --------------------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
}

enum LeadStatus {
  ACTIVE
  UNSUBSCRIBED
  CUSTOMER
}

model Lead {
  id               String      @id @default(cuid())
  email            String      @unique
  firstName        String?
  source           String?
  leadMagnet       String?
  entryPage        String?
  referrer         String?
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  utmContent       String?
  status           LeadStatus  @default(ACTIVE)
  subscribedAt     DateTime?
  unsubscribedAt   DateTime?
  ebookPurchasedAt DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  events           LeadEvent[]

  @@index([status, createdAt])
  @@index([source, createdAt])
  @@index([leadMagnet, createdAt])
  @@index([entryPage])
}

model LeadEvent {
  id        String   @id @default(cuid())
  leadId    String
  type      String
  page      String?
  metadata  Json?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([type, createdAt])
}
