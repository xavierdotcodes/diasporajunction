// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("MYSQL_URL")
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  name         String?
  phone        String?
  role         Role       @default(CUSTOMER)
  passwordHash String
  createdAt    DateTime   @default(now())
  orders       Order[]
  payments     Payment[]
}

enum Role {
  CUSTOMER
  ADMIN
}

//
// Products & Services
//
model Product {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  type        ProductType
  price       Float
  currency    String      @default("usd")
  location    String?
  duration    Int?        // in days
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime    @default(now())
  orders      Order[]
}

enum ProductType {
  SPACE
  NDGO
  TOUR
}

//
// Orders & Payments
//
model Order {
  id          Int        @id @default(autoincrement())
  user        User       @relation(fields: [userId], references: [id])
  userId      Int
  product     Product    @relation(fields: [productId], references: [id])
  productId   Int
  status      OrderStatus @default(PENDING)
  quantity    Int        @default(1)
  scheduledAt DateTime?
  createdAt   DateTime    @default(now())

  // one-to-one relation
  payment     Payment?
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Payment {
  id          Int        @id @default(autoincrement())
  order       Order      @relation(fields: [orderId], references: [id])
  orderId     Int        @unique   // <-- make unique for one-to-one
  user        User       @relation(fields: [userId], references: [id])
  userId      Int
  amount      Float
  currency    String
  reference   String     @unique
  provider    PaymentProvider
  status      PaymentStatus
  createdAt   DateTime   @default(now())
}

enum PaymentProvider {
  STRIPE
  MOMO
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}
